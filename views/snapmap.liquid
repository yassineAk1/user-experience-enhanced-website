{% render 'views/head.liquid' %}

<header>
  <nav class="header-nav">
    {% if snapmaps.size > 1 %}
      <details class="snapmap-dropdown">
        <summary class="map-title-btn">{{ snapmap.name }} ▾</summary>
        <ul class="snapmap-dropdown-list">
          {% for sm in snapmaps %}
            {% unless sm.uuid == snapmap.uuid %}
              <li>
                <a href="/snapmap/{{ sm.uuid }}">{{ sm.name }}</a>
              </li>
            {% endunless %}
          {% endfor %}
        </ul>
      </details>
    {% else %}
      <span class="map-title">{{ snapmap.name }}</span>
    {% endif %}
    <button class="nav-grid-btn" type="button" aria-label="Toon rasterweergave">
      <img src="/assets/grid.svg" alt="" width="22" height="22">
    </button>
  </nav>
</header>

<div class="success-box" id="succes" role="status">
  <p>Your snap has been added successfully!</p>
  <a href="#" class="status-banner-btn">OK</a>
</div>

<main>
  {% if groep %}
    <div class="group-bar">
      <img class="group-icon" src="/assets/GroupST-Copy.svg" alt="" width="20" height="20">
      <span class="group-bar-name">{{ groep.name }}</span>
    </div>
  {% endif %}

  <form
    method="POST"
    action="/snapmap/{{ snapmap.uuid }}"
    enctype="multipart/form-data"
    id="snap-form"
    class="camera-section"
  >
    <input type="file" name="file" accept="image/*" required id="snap-input" class="sr-only">
    <label for="snap-input" class="camera-btn">
      <img src="/assets/camera-alt.svg" alt="">
    </label>
    <div class="loader" id="loading-dots" hidden></div>
    <button type="submit" class="ok-btn" id="snap-submit">OK</button>
  </form>

  <div id="snap-preview" hidden>
    <img id="preview-img" src="/assets/placeholder.jpeg" alt="Preview foto">
    <div class="preview-actions">
      <label for="snap-input" class="gallery-btn">add from gallery</label>
      <button type="submit" form="snap-form" class="ok-btn">OK</button>
    </div>
  </div>

  <ul class="photo-grid">
    {% for snap in snaps %}
      <li class="photo-item">
        <a href="/snap/{{ snap.uuid }}">
          {% if snap.picture %}
            <picture>
              <source
                type="image/webp"
                srcset="https://fdnd-agency.directus.app/assets/{{ snap.picture }}?format=webp&width=400"
              >
              <img
                src="https://fdnd-agency.directus.app/assets/{{ snap.picture }}?width=400"
                alt="snap"
                loading="lazy"
                style="view-transition-name: snap-{{ snap.uuid }}"
              >
            </picture>
          {% else %}
            <img src="/assets/placeholder.jpeg" alt="" width="400" height="400" loading="lazy">
          {% endif %}
        </a>
      </li>
    {% endfor %}
  </ul>
</main>

{% render 'views/foot.liquid', activePage: activePage %}
<script type="module">
  const snapForm = document.querySelector('#snap-form')
  const photoGrid = document.querySelector('.photo-grid')
  const successBox = document.querySelector('#succes')
  const loadingDots = document.querySelector('#loading-dots')

  const getOkBtns = () => document.querySelectorAll('.ok-btn')

  snapForm.addEventListener('submit', async function (event) {
    // Stap 1: stop de browser — ga niet weg naar een nieuwe pagina zoals normaal
    event.preventDefault()

    // Stap 2: verberg de preview en toon de loading animatie zodat de gebruiker weet dat er iets gebeurt
    document.getElementById('snap-preview').hidden = true
    loadingDots.hidden = false
    getOkBtns().forEach(btn => { btn.disabled = true })

    // Stap 3: pak de foto uit de input en stop het in een pakketje (FormData)
    // FormData en niet URLSearchParams — URLSearchParams kan geen bestanden verwerken
    const formData = new FormData(snapForm)

    // Stap 4: stuur het pakketje naar de server, precies zoals de browser dat normaal zou doen
    // await = wacht hier tot de server klaar is voor je verdergaat
    const response = await fetch(snapForm.action, {
      method: snapForm.method,
      body: formData
    })

    // Stap 5: de server stuurt een volledige HTML-pagina terug — lees die in als tekst
    const responseText = await response.text()

    // Stap 6: knip alleen de foto-grid uit die HTML, de rest gooi je weg
    const parser = new DOMParser()
    const responseDOM = parser.parseFromString(responseText, 'text/html')
    const newPhotoGrid = responseDOM.querySelector('.photo-grid')

    // Stap 7: vervang de oude foto-grid met de nieuwe — nieuwe foto staat er nu in zonder pagina-reload
    photoGrid.innerHTML = newPhotoGrid.innerHTML

    // Stap 8: toon de success melding — de box stond er al in de HTML, alleen verborgen via CSS
    successBox.classList.add('visible')

    // Stap 9: verberg de loading animatie en maak knoppen weer klikbaar
    loadingDots.hidden = true
    getOkBtns().forEach(btn => { btn.disabled = false })

    // Stap 10: reset het formulier zodat de gebruiker opnieuw een foto kan kiezen
    snapForm.reset()
    document.getElementById('snap-submit').hidden = true
  })
</script>
